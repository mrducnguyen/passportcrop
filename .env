# Feature flags — set to false via .env.local (gitignored) to disable.

# Bundles face detection (TinyFaceDetector via TF.js, ~1.5 MB lazy chunk + 192 KB models).
VITE_FACE_DETECTION=true

# Bundles background removal (@imgly/background-removal ONNX, ~150 KB JS,
# models fetched from CDN at runtime and cached by the browser).
VITE_BG_REMOVAL=true
